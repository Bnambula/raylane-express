# ===================================================
# Files that must NEVER be uploaded to GitHub
# ===================================================

# Your secret keys — MOST IMPORTANT
.env.local
.env.*.local
.env

# Next.js build output (auto-generated, not needed on GitHub)
.next/
out/

# Node modules — too large, reinstalled automatically
node_modules/

# System files
.DS_Store
*.pem
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript build info
*.tsbuildinfo
next-env.d.ts
