# ============================================================
# RAYLANE EXPRESS — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file and rename it to:  .env.local
#   2. Fill in your real values below
#   3. NEVER commit .env.local to GitHub — it contains passwords
# ============================================================

# --- FIREBASE (your database + file storage) ---
# Get these from: console.firebase.google.com → Your Project → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=paste-your-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx

# --- ADMIN PROTECTION ---
# Choose any long random string — this is your admin dashboard password
# Example: raylane-admin-2024-kampala-mbale
ADMIN_SECRET=choose-a-long-secret-string-here

# --- AFRICA'S TALKING (SMS notifications) ---
# Get from: account.africastalking.com
AFRICASTALKING_USERNAME=raylane
AFRICASTALKING_API_KEY=paste-your-at-key-here

# --- MTN MOBILE MONEY API ---
# Get from: momodeveloper.mtn.com (register as a business)
MTN_MOMO_API_KEY=paste-mtn-key-here
MTN_MOMO_USER_ID=paste-mtn-user-id-here
MTN_MOMO_ENVIRONMENT=sandbox
# Change to: production   when you go live

# --- AIRTEL MONEY API ---
# Get from: developers.airtel.africa
AIRTEL_CLIENT_ID=paste-airtel-client-id
AIRTEL_CLIENT_SECRET=paste-airtel-secret
AIRTEL_ENVIRONMENT=staging
# Change to: production   when you go live
